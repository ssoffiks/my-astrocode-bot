# Токен бота из BotFather. Не отправляй его в чатах и не выкладывай в GitHub.
BOT_TOKEN=123456:replace_me

# Куда пользователь пишет, если есть вопрос по оплате.
SUPPORT_USERNAME=@your_username

# Файл базы данных. Для локального запуска можно оставить так.
DATABASE_PATH=./data/astrocode.sqlite

# Telegram ID администраторов через запятую. Узнать свой ID можно командой /myid.
ADMIN_IDS=
